@page "/"
@inject MiniWarehouse.Services.ProductService ProductService
@inject MiniWarehouse.Services.CategoryService CategoryService

<NavMenu />

<div class="grid">
    <div>
        <div class="card">
            <h3>Produkty</h3>

            <div style="display:flex; gap:8px; margin-bottom:8px; align-items:center">
                <input class="input" placeholder="Hledej podle nazvu" @bind="searchTerm" />

                @if (categories.Any())
                {
                    <InputSelect class="input" style="width:160px" @bind-Value="SelectedCategory.Id">
                        <option value="@Guid.Empty">Všechny kategorie</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id">
                                @category.Name
                            </option>
                        }
                    </InputSelect>
                }
                <button class="btn" @onclick="ApplyFilter">Filtruj</button>
            </div>

            <table class="table">
                <thead>
                    <tr>
                        <th>Jméno</th>
                        <th>Kategorie</th>
                        <th>Cena</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (displayed != null)
                    {
                        @foreach (var p in displayed)
                        {
                            <tr>
                                <td>@p.Name</td>
                                <td>@p.Description</td>
                                <td>@p.Price.ToString("0.00") Kč</td>
                                <td>
                                    <button class="btn ghost" @onclick="() => StartEdit(p)">Upravit</button>
                                    <button class="btn" @onclick="() => DeleteProduct(p)">Smazat</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div style="margin-top:12px" class="note">Celkem: <strong>@TotalDisplay</strong></div>
        </div>

        <div style="margin-top:12px" class="card">
            <h4>Pridat produkt</h4>

            <EditForm Model="@productCreate" OnValidSubmit="@CreateProductSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div style="display:flex;flex-direction:column;gap:8px">
                    <label class="label-misaligned">Nazev</label>
                    <input class="input" @bind="productCreate.Name" />
                    <ValidationMessage For="@(() => productCreate.Name)" />

                    <label>Kategorie</label>
                    @if (categories.Any())
                    {
                        <InputSelect class="input" @bind-Value="productCreate.CategoryId">
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">
                                    @category.Name
                                </option>
                            }
                        </InputSelect>
                    }
                    <ValidationMessage For="@(() => productCreate.CategoryId)" />

                    <label>Popis</label>
                    <input class="input" @bind="productCreate.Description" />
                    <ValidationMessage For="@(() => productCreate.Description)" />

                    <label>Cena</label>
                    <InputNumber class="input" @bind-value="productCreate.Price" step="0.01" />
                    <ValidationMessage For="@(() => productCreate.Price)" />

                    <div style="display:flex; gap:8px">
                        <button class="btn" type="submit">Pridat</button>
                        <button class="btn ghost" @onclick="ClearForm">Vymazat</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    <div>
        <div class="card">
            <h4>Detaily / Uprava</h4>
            @if (productEdit != null)
            {
                <EditForm Model="@productEdit" OnValidSubmit="@EditProductSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                    <div style="display:flex;flex-direction:column;gap:8px">
                        <label>Nazev</label>
                        <input class="input" @bind="productEdit.Name" />

                        <label>Kategorie</label>
                        @if (categories.Any())
                        {
                            <InputSelect class="input" @bind-Value="productEdit.CategoryId">
                                @foreach (var category in categories)
                                {
                                    <option value="@category.Id">
                                        @category.Name
                                    </option>
                                }
                            </InputSelect>
                        }
                        <ValidationMessage For="@(() => productEdit.CategoryId)" />

                        <label>Popis</label>
                        <input class="input" @bind="productEdit.Description" />
                        <ValidationMessage For="@(() => productEdit.Description)" />

                        <label>Cena</label>
                        <InputNumber class="input" @bind-value="productEdit.Price" step="0.01" />
                        <ValidationMessage For="@(() => productEdit.Price)" />

                        <div style="display:flex; gap:8px">
                            <button class="btn" type="submit">Ulozit</button>
                            <button class="btn ghost" @onclick="CancelEdit">Zrusit</button>
                        </div>
                    </div>

                </EditForm>
            }
            else
            {
                <div class="note">Vyberte produkt pro upravu</div>
            }
        </div>

        
    </div>
</div>

@code{
    private List<MiniWarehouse.Models.Product> displayed = new();
    private List<MiniWarehouse.Models.Category> categories = new();
    private MiniWarehouse.Models.Category SelectedCategory = new();
    private MiniWarehouse.Models.ProductCreate productCreate = new();
    private MiniWarehouse.Models.ProductCreate? productEdit = null;

    private string searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var all = await ProductService.GetAllAsync();
        categories = await CategoryService.GetAllAsync();

        displayed = all;
    }


    private void ApplyFilter()
    {

        var all = ProductService.GetAllAsync().Result;

        var list = all.Where(p =>
        (string.IsNullOrEmpty(searchTerm) || p.Name.Contains(searchTerm)) &&
        (SelectedCategory.Id == Guid.Empty || p.Category.Id == SelectedCategory.Id)
        ).ToList();

        displayed = list;
    }

    private async Task CreateProductSubmit()
    {
        await ProductService.AddAsync(productCreate);

        productCreate = new();

        var all = await ProductService.GetAllAsync();
        displayed = all;
    }   

    private async Task DeleteProduct(MiniWarehouse.Models.Product p)
    {

        var all = await ProductService.GetAllAsync();
        var index = all.FindIndex(x => x.Id == p.Id);
        if (index >= 0)
        {
            await ProductService.RemoveByIndexAsync(index);
            displayed = await ProductService.GetAllAsync();
        }
    }

    private void StartEdit(MiniWarehouse.Models.Product p)
    {
        productEdit = new()
        {
            Id = p.Id,
            Name = p.Name,
            CategoryId = p.Category.Id,
            Description = p.Description,
            Price = p.Price
        };
    }


    private async Task EditProductSubmit()
    {
        if (productEdit == null) return;

        await ProductService.UpdateAsync(productEdit.Id, productEdit);

        productEdit = null;
        displayed = await ProductService.GetAllAsync();
    }


    private void CancelEdit()
    {
        productEdit = null;
    }


    private void ClearForm()
    {
        productCreate = new();
    }

 
    private string TotalDisplay
    {
        get
        {
            var all = displayed ?? new List<MiniWarehouse.Models.Product>();

            decimal total = all.Sum(x => x.Price);
            return total.ToString("0.00") + " Kč";
        }
    }
      
}  
